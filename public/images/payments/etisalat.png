<!-- slider for mobile start-->
<script>
$(document).ready(function() {
if($(window).width() <= 767){ 
              var owl = $('.Our-Platforms .owl-carousel');
              owl.owlCarousel({
                rtl: false,
                margin: 15,
                responsive: {
                  0: {
                    items: 1,
                  },
              	  480: {
                    items: 2,
                  },
                }
              })
  }
 });
 </script>
<!-- slider for mobile end-->

</body>

</html>

